  "cases": [
    {
      "id": "simple-01-q01",
      "file": "simple/01_门店月度销售.xlsx",
      "question": "哪家门店上半年总销售额最高？各门店排名如何？ 请输出结构化结果表（Excel 或 CSV），不要只在报告里写结论；结果表中保留用于核对的关键数值。",
      "tests": [
        "分组聚合",
        "排序",
        "数值准确率"
      ],
      "assertions": {
        "expected_row_count": {
          "name": "门店排名行数",
          "count": 5
        },
        "expected_values": [
          {
            "name": "杭州西湖店总销售额",
            "row_contains": "杭州西湖店",
            "expected": 753.3,
            "abs_tol": 0.01
          },
          {
            "name": "北京旗舰店总销售额",
            "row_contains": "北京旗舰店",
            "expected": 739.7,
            "abs_tol": 0.01
          },
          {
            "name": "上海南京路店总销售额",
            "row_contains": "上海南京路店",
            "expected": 664.9,
            "abs_tol": 0.01
          },
          {
            "name": "广州天河店总销售额",
            "row_contains": "广州天河店",
            "expected": 664.8,
            "abs_tol": 0.01
          },
          {
            "name": "成都春熙路店总销售额",
            "row_contains": "成都春熙路店",
            "expected": 566.7,
            "abs_tol": 0.01
          }
        ],
        "report_must_mention": [
          {
            "name": "最高门店",
            "terms": [
              "杭州西湖店",
              "最高"
            ],
            "within_chars": 120,
            "required": false
          }
        ]
      }
    },
